# Adam Chip — environment variable template
# Copy to .env and adjust for your deployment.
# All values shown are the production defaults for the Jetson Orin NX.

# ── Orchestrator ────────────────────────────────────────────────────
ADAM_MODE=maintenance
ADAM_CONFIG=System/Config.json
ADAM_DATA_DIR=data/adam

# ── ESP32 MCU (static IP) ────────────────────────────────────────────
ESP_BASE_URL=http://192.168.0.171
ESP_SPEAKER_URL=http://192.168.0.171:83/speaker

# ── LLM — llama.cpp (OpenAI-compatible, port 8081) ───────────────────
ADAM_LLM_PROVIDER=openai
ADAM_LLM_BASE_URL=http://127.0.0.1:8081/v1
ADAM_LLM_MODEL=gemma-4-E4B-it-UD-Q4_K_XL

# ── ASR — speaches / faster-whisper (port 8083) ──────────────────────
ADAM_ASR_HOST=127.0.0.1
ADAM_ASR_PORT=8083

# ── TTS — Silero HTTP (port 8082) ────────────────────────────────────
ADAM_TTS_BASE_URL=http://127.0.0.1:8082

# ── VLM — VILA via nano_llm Docker (port 8084) ───────────────────────
ADAM_VLM_BASE_URL=http://127.0.0.1:8084
ADAM_VLM_MODEL=Efficient-Large-Model/VILA1.5-3b

# ── Media devices ────────────────────────────────────────────────────
ADAM_VIDEO_DEVICE=/dev/video0
ADAM_AUDIO_INPUT_DEVICE=pulse           # PulseAudio mic (WebCamera card 3)
ADAM_AUDIO_OUTPUT_DEVICE=default

# ── Sounds ───────────────────────────────────────────────────────────
ADAM_SOUNDS_ENABLED=1
ADAM_SUCCESS_SOUND=data/sounds/success.wav

# ── ASR Whisper standalone service (System/Speech/ASR_Whisper.py) ────
ADAM_ASR_WHISPER_MODEL=base
ADAM_ASR_LANGUAGE=ru
ADAM_ASR_DEVICE=auto
ADAM_ASR_COMPUTE_TYPE=auto
ADAM_ASR_SAMPLE_RATE=16000
ADAM_MODELS_DIR=Subsystem/Models

# ── TTS Silero standalone service (System/Speech/TTS.py) ─────────────
ADAM_TTS_HOST=0.0.0.0
ADAM_TTS_PORT=8082
ADAM_TTS_OUTPUT_DEVICE=plughw:1,3      # ALSA HDMI, card 0 HDA NVIDIA
ADAM_TTS_PLAYBACK=1

# ── VLM standalone service (System/Speech/VLM.py) ────────────────────
ADAM_VLM_HOST=0.0.0.0
ADAM_VLM_PORT=8084
ADAM_VLM_MAX_TOKENS=48
