{
    "configurations": [
        {
            "name": "Jetson Host",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "windowsSdkVersion": "10.0.26100.0",
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-msvc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        },
        {
            "name": "ESP32-S3 Arduino",
            "compilerPath": "${config:adamchip.esp32.compilerPath}",
            "includePath": [
                "${workspaceFolder}/Subsystem/AdamsServer",
                "${workspaceFolder}/Subsystem/AdamsServer/**",
                "${config:adamchip.esp32.arduinoCore}",
                "${config:adamchip.esp32.variantPath}",
                "${config:adamchip.esp32.arduinoLibraries}/**",
                "${config:adamchip.esp32.libsRoot}/include/**",
                "${config:adamchip.esp32.cameraInclude}",
                "${config:adamchip.esp32.sdkconfigInclude}"
            ],
            "defines": [
                "ARDUINO=10819",
                "ARDUINO_ARCH_ESP32",
                "ARDUINO_ESP32S3_DEV",
                "ESP32",
                "ESP_PLATFORM",
                "CONFIG_IDF_TARGET_ESP32S3"
            ],
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64",
            "browse": {
                "path": [
                    "${workspaceFolder}/Subsystem/AdamsServer",
                    "${config:adamchip.esp32.arduinoCore}",
                    "${config:adamchip.esp32.variantPath}",
                    "${config:adamchip.esp32.arduinoLibraries}",
                    "${config:adamchip.esp32.libsRoot}/include",
                    "${config:adamchip.esp32.cameraInclude}",
                    "${config:adamchip.esp32.sdkconfigInclude}"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
