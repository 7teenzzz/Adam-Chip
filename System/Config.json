{
  "agent": {
    "name": "Адам Чип",
    "language": "ru-RU",
    "mode": "maintenance",
    "data_dir": "data/adam",
    "persona_paths": [
      "Agent Adam Chip/About/System.md",
      "Agent Adam Chip/About/Identity.md",
      "Agent Adam Chip/About/Lore.md",
      "Agent Adam Chip/About/Abilities.md"
    ],
    "history_turns": 2,
    "prompt_trace_max": 50
  },
  "power": {
    "required_mode_name": "MAXN",
    "required_mode_id": 0,
    "require_jetson_clocks": true,
    "enforce_in_exhibition": true
  },
  "media": {
    "video": {
      "primary": "jetson_gstreamer",
      "gstreamer_pipeline": "v4l2src device=/dev/video0 ! image/jpeg,framerate=30/1 ! jpegdec ! videoconvert ! video/x-raw,format=RGB ! appsink name=adam_frames drop=true max-buffers=1 sync=false",
      "remote_rtsp_url": "",
      "preview_enabled": true,
      "video_device": "/dev/video0",
      "camera_width": 640,
      "camera_height": 480,
      "camera_quality": 75,
      "camera_capture_interval_sec": 0.5
    },
    "audio": {
      "input_device": "pulse",
      "output_device": "default",
      "sample_rate": 16000,
      "channels": 1,
      "frame_ms": 20,
      "vad_threshold": 400,
      "min_speech_ms": 404,
      "max_segment_ms": 9000,
      "normalize_factor": 8000
    },
    "scene_worker_enabled": true,
    "scene_interval_sec": 4,
    "scene_stale_after_sec": 8,
    "scene_buffer_maxlen": 8,
    "scene_context_count": 1
  },
  "services": {
    "llm": {
      "provider": "openai",
      "base_url": "http://127.0.0.1:8081/v1",
      "model": "gemma-4-E4B-it-UD-Q4_K_XL",
      "timeout_sec": 60,
      "temperature": 0.7,
      "max_tokens": 40,
      "num_ctx": 8192
    },
    "vlm": {
      "base_url": "http://127.0.0.1:8084",
      "model": "Efficient-Large-Model/VILA1.5-3b",
      "timeout_sec": 20,
      "max_new_tokens": 24,
      "prompt": "Briefly describe the scene in one sentence: people present, movement, notable objects."
    },
    "asr": {
      "provider": "speaches",
      "base_url": "http://127.0.0.1:8083",
      "model": "Systran/faster-whisper-small",
      "language": "ru",
      "endpointing_ms": 200,
      "sample_rate": 16000,
      "timeout_sec": 30,
      "barge_in_enabled": false,
      "post_tts_cooldown_sec": 2.0,
      "wake_words": "адам,дохлый",
      "wake_word_required": true
    },
    "tts": {
      "provider": "silero",
      "base_url": "http://127.0.0.1:8082",
      "model": "v5_5_ru",
      "speaker": "eugene",
      "sample_rate": 48000,
      "timeout_sec": 20,
      "available_speakers": [
        "aidar",
        "baya",
        "kseniya",
        "xenia",
        "eugene",
        "random"
      ],
      "output_device": "plughw:1,3"
    }
  },
  "mcu": {
    "base_url": "http://192.168.0.171",
    "speaker_url": "http://192.168.0.171:83/speaker",
    "timeout_sec": 1,
    "idle_scene": "boot_idle",
    "allowed_scenes": [
      "boot_idle",
      "all_on",
      "alternating"
    ],
    "channels": {
      "min": 0,
      "max": 15,
      "value_min": 0,
      "value_max": 4095
    }
  },
  "sounds": {
    "enabled": true,
    "success_path": "data/sounds/success.wav",
    "local_output_device": "default",
    "esp_boot_note": "ESP boot sound is embedded in ESP firmware and played by ESP after speaker init"
  },
  "safety": {
    "motor_default_duration_ms": 900,
    "motor_max_duration_ms": 2500,
    "motor_cooldown_ms": 250,
    "half_duplex_mute": true
  }
}
