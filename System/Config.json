{
  "agent": {
    "name": "Адам Чип",
    "language": "ru-RU",
    "mode": "maintenance",
    "data_dir": "data/adam",
    "persona_paths": [
      "Agent Adam Chip/About/System.md",
      "Agent Adam Chip/About/Identity.md",
      "Agent Adam Chip/About/Lore.md",
      "Agent Adam Chip/About/Abilities.md"
    ],
    "history_turns": 2
  },
  "power": {
    "required_mode_name": "MAXN",
    "required_mode_id": 0,
    "require_jetson_clocks": true,
    "enforce_in_exhibition": true
  },
  "media": {
    "video": {
      "primary": "jetson_gstreamer",
      "video_device": "/dev/video0",
      "camera_width": 640,
      "camera_height": 480,
      "camera_quality": 75,
      "camera_capture_interval_sec": 0.5,
      "remote_rtsp_url": "",
      "preview_enabled": true
    },
    "audio": {
      "input_device": "pulse",
      "output_device": "default",
      "sample_rate": 16000,
      "channels": 1,
      "frame_ms": 20,
      "vad_threshold": 650,
      "min_speech_ms": 400,
      "max_segment_ms": 9000
    },
    "scene_worker_enabled": true,
    "scene_interval_sec": 2,
    "scene_stale_after_sec": 20,
    "scene_buffer_maxlen": 8,
    "scene_context_count": 1
  },
  "services": {
    "llm": {
      "provider": "openai",
      "base_url": "http://127.0.0.1:8051/v1",
      "model": "gemma-4-E4B-it-UD-Q4_K_XL",
      "timeout_sec": 60,
      "temperature": 0.7,
      "max_tokens": 40,
      "num_ctx": 8192
    },
    "vlm": {
      "base_url": "http://127.0.0.1:8050",
      "model": "Efficient-Large-Model/VILA1.5-3b",
      "timeout_sec": 10,
      "max_new_tokens": 24,
      "prompt": "Briefly describe the scene in one sentence: people present, movement, notable objects."
    },
    "asr": {
      "provider": "speaches",
      "base_url": "http://127.0.0.1:8000",
      "model": "Systran/faster-whisper-small",
      "language": "ru",
      "sample_rate": 16000,
      "timeout_sec": 30,
      "endpointing_ms": 200,
      "barge_in_enabled": true,
      "wake_words": "адам,дохлый",
      "wake_word_required": true,
      "_whisper_fallback": {
        "provider": "whisper",
        "base_url": "http://127.0.0.1:8095",
        "model": "tiny"
      },
      "_riva": {
        "host": "127.0.0.1",
        "port": 50051,
        "language_code": "ru-RU",
        "endpointing_ms": 450,
        "audio_channel_count": 1,
        "chunk_bytes": 3200
      }
    },
    "tts": {
      "provider": "silero",
      "base_url": "http://127.0.0.1:8090",
      "model": "v5_5_ru",
      "speaker": "eugene",
      "sample_rate": 48000,
      "timeout_sec": 20,
      "output_device": "plughw:0,3"
    }
  },
  "mcu": {
    "base_url": "http://192.168.0.172",
    "speaker_url": "http://192.168.0.172:83/speaker",
    "timeout_sec": 1,
    "idle_scene": "boot_idle",
    "allowed_scenes": [
      "boot_idle",
      "all_on",
      "alternating"
    ],
    "channels": {
      "min": 0,
      "max": 15,
      "value_min": 0,
      "value_max": 4095
    }
  },
  "sounds": {
    "enabled": true,
    "success_path": "data/sounds/success.wav",
    "local_output_device": "default",
    "esp_boot_note": "ESP boot sound is embedded in ESP firmware and played by ESP after speaker init"
  },
  "safety": {
    "motor_default_duration_ms": 900,
    "motor_max_duration_ms": 2500,
    "motor_cooldown_ms": 250,
    "half_duplex_mute": true
  }
}
