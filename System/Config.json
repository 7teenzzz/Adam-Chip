{
  "agent": {
    "name": "Adam Chip",
    "language": "ru-RU",
    "mode": "maintenance",
    "data_dir": "data/adam",
    "persona_paths": [
      "Agent Adam Chip/About/BIO.md",
      "Agent Adam Chip/About/Abilities.md"
    ],
    "history_turns": 8
  },
  "power": {
    "required_mode_name": "MAXN",
    "required_mode_id": 0,
    "require_jetson_clocks": true,
    "enforce_in_exhibition": true
  },
  "media": {
    "video": {
      "primary": "jetson_gstreamer",
      "gstreamer_pipeline": "v4l2src device=/dev/video0 ! image/jpeg,framerate=30/1 ! jpegdec ! videoconvert ! video/x-raw,format=RGB ! appsink name=adam_frames drop=true max-buffers=1 sync=false",
      "remote_rtsp_url": "",
      "preview_enabled": false
    },
    "audio": {
      "input_device": "hw:0,0",
      "output_device": "default",
      "sample_rate": 16000,
      "channels": 1,
      "frame_ms": 20,
      "vad_threshold": 650,
      "min_speech_ms": 280,
      "max_segment_ms": 9000
    },
    "scene_worker_enabled": true,
    "scene_interval_sec": 8,
    "scene_stale_after_sec": 20
  },
  "services": {
    "llm": {
      "provider": "ollama",
      "base_url": "http://127.0.0.1:11434",
      "model": "gemma3:4b",
      "timeout_sec": 30,
      "temperature": 0.7,
      "max_tokens": 220
    },
    "vlm": {
      "base_url": "http://127.0.0.1:8050",
      "model": "Efficient-Large-Model/VILA1.5-3b",
      "timeout_sec": 10,
      "max_new_tokens": 32
    },
    "asr": {
      "provider": "riva",
      "host": "127.0.0.1",
      "port": 50051,
      "language_code": "ru-RU",
      "endpointing_ms": 450,
      "sample_rate": 16000,
      "audio_channel_count": 1,
      "chunk_bytes": 3200
    },
    "tts": {
      "provider": "silero",
      "base_url": "http://127.0.0.1:8090",
      "model": "v5_5_ru",
      "speaker": "eugene",
      "sample_rate": 48000,
      "output_sample_rate": 16000,
      "timeout_sec": 20
    }
  },
  "mcu": {
    "base_url": "http://192.168.0.172",
    "speaker_url": "http://192.168.0.172:83/speaker",
    "timeout_sec": 3,
    "idle_scene": "boot_idle",
    "allowed_scenes": [
      "boot_idle",
      "all_on",
      "alternating"
    ],
    "channels": {
      "min": 0,
      "max": 15,
      "value_min": 0,
      "value_max": 4095
    }
  },
  "safety": {
    "motor_default_duration_ms": 900,
    "motor_max_duration_ms": 2500,
    "motor_cooldown_ms": 250,
    "half_duplex_mute": true
  },
  "sounds": {
    "enabled": true,
    "success_path": "data/sounds/success.mp3",
    "local_output_device": "default",
    "esp_boot_note": "ESP boot sound is embedded in ESP firmware and played by ESP after speaker init"
  }
}
