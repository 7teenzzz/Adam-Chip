{
  "_meta": {
    "version": 1,
    "comment": "Runtime-параметры персоны и поведения. Hot-reload, редактируется через UI. Инфраструктура (камеры, MCU, модели LLM/ASR/TTS endpoints) — в System/Config.json."
  },
  "memory": {
    "episodic": {
      "enabled": true,
      "salience_threshold": 0.4,
      "decay_days": 14,
      "duration_normalize_seconds": 300,
      "weights": {
        "introduced_name": 0.3,
        "duration": 0.2,
        "themes": 0.15,
        "tone": 0.15,
        "echoes_used": 0.1,
        "new_question": 0.1
      },
      "highlights_max_per_episode": 6,
      "recurring_min_visits": 2,
      "recurring_lookup_days": 90
    },
    "semantic": {
      "enabled": true,
      "max_chars": 2000
    },
    "recent_injection": {
      "enabled": true,
      "limit": 2,
      "strategy": "by_name",
      "max_age_days": 30
    },
    "theme_clusters": {
      "память": ["помнишь", "забыл", "прошлое", "вспомни", "память", "вспоминаю"],
      "смерть": ["умрёшь", "умер", "умирать", "конец", "смерть", "погибнуть", "умру"],
