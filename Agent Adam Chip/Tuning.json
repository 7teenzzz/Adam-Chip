{
  "_meta": {
    "version": 1,
    "comment": "Runtime-параметры персоны и поведения. Hot-reload, редактируется через UI. Инфраструктура (камеры, MCU, модели LLM/ASR/TTS endpoints) — в System/Config.json."
  },
  "memory": {
    "episodic": {
      "enabled": true,
      "salience_threshold": 0.4,
      "decay_days": 14,
      "duration_normalize_seconds": 300,
      "weights": {
        "introduced_name": 0.3,
        "duration": 0.2,
        "themes": 0.15,
        "tone": 0.15,
        "echoes_used": 0.1,
        "new_question": 0.1
      },
      "highlights_max_per_episode": 6
    },
    "semantic": {
      "enabled": true,
      "max_chars": 4000
    },
    "recent_injection": {
      "enabled": true,
      "limit": 2,
      "strategy": "by_name",
      "max_age_days": 30
    },
    "consolidator": {
      "enabled": true,
      "model": null,
      "window_start": "03:00",
      "window_end": "05:00",
      "max_episodes_per_run": 200,
      "temperature": 0.3,
      "max_runtime_minutes": 30,
      "retry_on_invalid_patch": false
    }
  },
  "echoes": {
    "enabled": true,
    "global_cooldown_turns": 12,
    "per_echo_cooldown_days": 7,
    "match_threshold": 0.55,
    "weight_multiplier": 1.0,
    "matcher_type": "tag"
  },
  "chinese": {
    "enabled": true,
    "global_cooldown_turns": 30,
    "per_echo_cooldown_days": 7,
    "match_threshold": 0.65,
    "weight_multiplier": 1.0,
    "audio_mode": "prerendered_with_text_fallback"
  },
  "session": {
    "end_strategy": "combined",
    "vad_silence_seconds": 60,
    "face_lost_seconds": 15,
    "grace_message": "вы там?"
  },
  "scene_director": {
    "enabled": true,
    "sustain_seconds": 8,
    "cooldown_between_changes_seconds": 5,
    "hysteresis_seconds": 15,
    "override_priority_scenes": [
      "unease"
    ]
  },
  "llm": {
    "temperature": 0.7,
    "max_tokens": 200,
    "response_word_target": 30
  },
  "voice": {
    "speaker": "eugene",
    "speed_multiplier": 1.0,
    "volume": 1.0
  },
  "prompt": {
    "history_turns": 8,
    "include_scene": true,
    "include_sensors": true
  },
  "diagnostics": {
    "log_level": "info",
    "metrics_enabled": true,
    "trace_prompts": false
  }
}